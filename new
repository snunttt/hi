local function getRealGame()
    local g = game

    if g.Name == "Ugc" then
        local env = (getrenv and getrenv()) or (getgenv and getgenv()) or shared or {}

        g = env.game or g

        if typeof(g) == "userdata" and g.Name == "Ugc" then
            g = (cloneref and cloneref(game)) or game
        end
    end

    return g
end

local realGame = getRealGame()

local Players = realGame:GetService("Players")
local RS = realGame:GetService("ReplicatedStorage")

local localPlayer = Players.LocalPlayer

while not localPlayer do
    Players:GetPropertyChangedSignal("LocalPlayer"):Wait()
    localPlayer = Players.LocalPlayer
end


local function killCharacter(char)
    if not char then return end

    local hum = char:FindFirstChildWhichIsA("Humanoid")

    if hum then
        hum.Health = -1
    end
end


local function getJoinRemote()
    local remotes = RS:FindFirstChild("Remotes")
    local matchmaking = remotes and remotes:FindFirstChild("Matchmaking")

    return matchmaking and matchmaking:FindFirstChild("JoinQueue")
end


local join = getJoinRemote()

if join then
    task.spawn(function()
        while true do
            pcall(function()
                join:InvokeServer("1v1")
            end)

            task.wait(2)
        end
    end)
end


-- handles reset/respawn
localPlayer.CharacterAdded:Connect(function(char)
    task.wait(0.5)

    killCharacter(char)

    join = getJoinRemote()
end)


-- kill current character if already spawned
if localPlayer.Character then
    killCharacter(localPlayer.Character)
end
